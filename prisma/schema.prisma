generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  THERAPIST
  CLIENT
}

enum AppointmentRequestStatus {
  PENDING
  CONFIRMED
  DECLINED
  PROPOSED
  CANCELLED
}

enum AppointmentStatus {
  CONFIRMED
  COMPLETED
  CANCELLED
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  passwordHash        String
  role                UserRole             @default(CLIENT)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  sessions            Session[]
  therapistProfile    TherapistProfile?
  clientRequests      AppointmentRequest[] @relation("ClientRequests")
  therapistRequests   AppointmentRequest[] @relation("TherapistRequests")
  clientAppointments  Appointment[]        @relation("ClientAppointments")
  therapistAppointments Appointment[]      @relation("TherapistAppointments")
  sentMessages        ContactMessage[]     @relation("SentMessages")
  receivedMessages    ContactMessage[]     @relation("ReceivedMessages")
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model TherapistProfile {
  id            String         @id @default(cuid())
  userId        String         @unique
  bio           String?
  specialty     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  availabilities Availability[]
}

model Availability {
  id                String          @id @default(cuid())
  therapistProfileId String
  weekday           Int
  startMinutes     Int
  endMinutes       Int
  timezone         String          @default("America/Sao_Paulo")
  isActive         Boolean         @default(true)
  therapistProfile TherapistProfile @relation(fields: [therapistProfileId], references: [id], onDelete: Cascade)

  @@index([therapistProfileId, weekday, isActive])
}

model AppointmentRequest {
  id                String                    @id @default(cuid())
  clientId          String
  therapistId       String
  desiredStart      DateTime
  proposedStart     DateTime?
  durationMinutes   Int                       @default(50)
  message           String
  adminNote         String?
  status            AppointmentRequestStatus  @default(PENDING)
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  client            User                      @relation("ClientRequests", fields: [clientId], references: [id], onDelete: Cascade)
  therapist         User                      @relation("TherapistRequests", fields: [therapistId], references: [id], onDelete: Restrict)
  appointment       Appointment?
  contactMessages   ContactMessage[]

  @@index([clientId, status, createdAt])
  @@index([therapistId, desiredStart, status])
}

model Appointment {
  id                  String              @id @default(cuid())
  requestId           String              @unique
  clientId            String
  therapistId         String
  startAt             DateTime
  endAt               DateTime
  status              AppointmentStatus   @default(CONFIRMED)
  adminNote           String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  request             AppointmentRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  client              User                @relation("ClientAppointments", fields: [clientId], references: [id], onDelete: Cascade)
  therapist           User                @relation("TherapistAppointments", fields: [therapistId], references: [id], onDelete: Restrict)
  contactMessages     ContactMessage[]

  @@index([clientId, startAt, status])
  @@index([therapistId, startAt, status])
}

model ContactMessage {
  id                   String              @id @default(cuid())
  senderId             String
  recipientId          String
  appointmentRequestId String?
  appointmentId        String?
  subject              String
  body                 String
  readAt               DateTime?
  createdAt            DateTime            @default(now())
  sender               User                @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  recipient            User                @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: Cascade)
  appointmentRequest   AppointmentRequest? @relation(fields: [appointmentRequestId], references: [id], onDelete: SetNull)
  appointment          Appointment?        @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([recipientId, readAt, createdAt])
  @@index([senderId, createdAt])
  @@index([appointmentRequestId, createdAt])
  @@index([appointmentId, createdAt])
}
